{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    // Tests can use exactOptionalPropertyTypes loosely — keep rest strict
    "exactOptionalPropertyTypes": false,
    "noEmit": true
  },
  "include": ["src", "tests"]
}
