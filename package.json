{
  "name": "hono-tanstack-query",
  "version": "0.1.0",
  "description": "TanStack Query bindings for Hono typed clients — fully typed, zero boilerplate",
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "homepage": "https://github.com/adil6572/hono-tanstack-query#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adil6572/hono-tanstack-query.git"
  },
  "bugs": {
    "url": "https://github.com/adil6572/hono-tanstack-query/issues"
  },
  "keywords": [
    "hono",
    "tanstack-query",
    "react-query",
    "typescript",
    "rpc"
  ],
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --project tsconfig.build.json --noEmit",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --project tsconfig.test.json --noEmit",
    "check": "npm run build:check && npm run lint && npm run format:check && npm run test",
    "publint": "publint",
    "attw": "attw --pack",
    "prepack": "npm run build",
    "release": "npm run check && npm run publint && npm run attw && changeset publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "hono": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@changesets/cli": "^2.27.0",
    "@tanstack/react-query": "^5.90.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "hono": "^4.6.0",
    "husky": "^9.0.0",
    "jiti": "^2.6.1",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "publint": "^0.2.12",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}